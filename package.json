{
  "name": "ghost-launcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:ui-guidelines": "node scripts/check-ui-guidelines.mjs",
    "test:ui-guidelines-check": "node --test scripts/check-ui-guidelines.test.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "e2e:setup": "cargo install tauri-driver --locked && npx tauri build --no-bundle",
    "e2e": "playwright test -c playwright.tauri.config.ts"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-icons": "^2.0.326",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "i18next": "^25.10.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^16.6.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "edgedriver": "^6.3.0",
    "jsdom": "^28.1.0",
    "selenium-webdriver": "^4.43.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
